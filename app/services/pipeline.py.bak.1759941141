from __future__ import annotations
from pathlib import Path
import sys, importlib, runpy
from types import ModuleType
from typing import List, Optional

LEGACY_MODULE = "legacy_cli.pipeline_evalnat"

def _call_cli_like(module: ModuleType, argv: List[str]) -> None:
    main = getattr(module, "main", None)
    if callable(main):
        try:
            # cas main(argv)
            return main(argv)
        except TypeError:
            # cas main() qui lit sys.argv
            old = sys.argv
            try:
                sys.argv = [LEGACY_MODULE] + argv
                return main()
            except SystemExit as se:
                code = getattr(se, 'code', '?')
                raise RuntimeError(f"Le pipeline legacy s'est arrêté (SystemExit {code}). Vérifie les options transmises.") from se
            finally:
                sys.argv = old
        except SystemExit as se:
            code = getattr(se, 'code', '?')
            raise RuntimeError(f"Le pipeline legacy s'est arrêté (SystemExit {code}). Vérifie les options transmises.") from se

    # fallback: exécuter le script comme __main__
    spec = getattr(module, "__spec__", None)
    file_path = spec.origin if spec and getattr(spec, "origin", None) else None
    if not file_path:
        pkg = importlib.import_module("legacy_cli")
        candidate = Path(pkg.__file__).parent / "pipeline_evalnat.py"
        if candidate.exists():
            file_path = str(candidate)
    if not file_path:
        raise RuntimeError("Impossible de localiser legacy_cli/pipeline_evalnat.py")

    old = sys.argv
    try:
        sys.argv = [file_path] + argv
        runpy.run_path(file_path, run_name="__main__")
    finally:
        sys.argv = old

def run_pipeline(
    pdf_path: Path,
    csv_path: Path,
    annee: str,
    classe: str,
    out_dir: Path,
    no_split: bool = False,
    message_text: Optional[str] = None,
) -> None:
    out_dir.mkdir(parents=True, exist_ok=True)
    argv: List[str] = [
        "--classe", classe,
        "--annee", annee,
        "--out-dir", str(out_dir),
        "--parents", str(csv_path),
        "--input-pdf", str(pdf_path),
    ]
    if no_split:
        argv.append("--no-split")
    if message_text:
        argv += ["--message-text", message_text]

    try:
        mod = importlib.import_module(LEGACY_MODULE)
    except ModuleNotFoundError as e:
        raise RuntimeError("Module legacy introuvable : vérifie legacy_cli/__init__.py et pipeline_evalnat.py") from e
    print("[legacy argv]", " ".join(argv), file=sys.stderr)
    _call_cli_like(mod, argv)